{
  "name": "vease",
  "version": "0.0.0",
  "description": "Desktop and cloud software for data visualization",
  "keywords": [
    "Desktop",
    "Geology",
    "Meshing",
    "Visualization",
    "Web"
  ],
  "homepage": "https://github.com/Geode-solutions/Vease#readme",
  "bugs": {
    "url": "https://github.com/Geode-solutions/Vease/issues"
  },
  "license": "MIT",
  "author": "Geode-solutions",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Geode-solutions/Vease.git"
  },
  "type": "module",
  "main": "dist-electron/main.js",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean_cache": "npx nuxi cleanup",
    "dev": "npm run dev:browser",
    "dev:browser": "cross-env BROWSER=true npm run dev:nuxt",
    "dev:desktop": "npm run dev:nuxt",
    "dev:nuxt": "npm run clean_cache && npx nuxi dev --no-fork",
    "build:back": "npx opengeodeweb-microservice-pyinstaller ../Vease-Back",
    "build:viewer": "npx opengeodeweb-microservice-pyinstaller ../Vease-Viewer",
    "build:microservices": "concurrently \"npm run build:back\" \"npm run build:viewer\"",
    "build": "nuxi build",
    "build:browser": "cross-env BROWSER=true npm run build",
    "build:desktop": "npm run build && electron-builder --dir",
    "preview:browser": "node .output/server/index.mjs",
    "generate": "nuxt generate",
    "package": "npm run build && electron-builder build --publish=never",
    "test:e2e:browser": "npx playwright test --config ./tests/e2e/browser/playwright.config.js",
    "test:e2e:cloud": "npx playwright test --config ./tests/e2e/cloud/playwright.config.js",
    "test:e2e:desktop": "npx playwright test --config ./tests/e2e/desktop/playwright.config.js"
  },
  "dependencies": {
    "@fontsource/michroma": "5.2.6",
    "@geode/opengeodeweb-back": "0.0.0",
    "@geode/opengeodeweb-front": "0.0.0",
    "@geode/opengeodeweb-viewer": "0.0.0",
    "@geode/vease-back": "0.0.0",
    "@geode/vease-viewer": "0.0.0",
    "broadcast-channel": "7.1.0",
    "bufferutil": "4.0.9",
    "draggable": "4.2.0",
    "electron-updater": "6.6.2",
    "h3-formidable": "1.0.0",
    "kill-port": "2.0.1",
    "utf-8-validate": "6.0.5"
  },
  "devDependencies": {
    "@nuxt/test-utils": "3.20.1",
    "@playwright/test": "1.54.1",
    "concurrently": "9.2.1",
    "cross-env": "10.0.0",
    "electron": "36.4.0",
    "electron-builder": "26.0.12",
    "electron-playwright-helpers": "1.7.1",
    "nuxt-electron": "0.7.0",
    "playwright": "1.54.1",
    "std-env": "3.9.0"
  }
}
